# Copy this file to .env and fill in your key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Start with Sonnet for the quality/speed balance.
# Swap to claude-haiku-4-5-20251001 for speed/cost, or claude-opus-4-8 for max accuracy.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Storage. Leave DATABASE_URL unset to use a local SQLite file (development).
# In production, set it to your managed Postgres connection string, e.g.:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
# A plain 'postgres://' URL from a host is fine too; the app rewrites it.
# DATABASE_URL=
